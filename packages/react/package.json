{
  "name": "@madinah/mdx-handwritten-react",
  "version": "0.1.0",
  "description": "Server-renderable React components for MDX Handwritten",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/index.js",
    "dist/index.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@madinah/mdx-handwritten-scene": "*"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maidang1/mdx-handwritten.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Maidang1/mdx-handwritten#readme",
  "bugs": {
    "url": "https://github.com/Maidang1/mdx-handwritten/issues"
  },
  "keywords": [
    "mdx",
    "react",
    "handwritten",
    "annotation"
  ]
}
