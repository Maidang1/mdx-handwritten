{
  "name": "@madinah/mdx-handwritten-scene",
  "version": "0.1.0",
  "description": "Deterministic semantic Scene plans for MDX Handwritten",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./recipes": {
      "types": "./dist/recipes.d.ts",
      "import": "./dist/recipes.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/recipes.ts --format esm --sourcemap --clean --minify terser --tsconfig tsconfig.build.json && tsup src/index.ts --format esm --dts --dts-only --clean false --tsconfig tsconfig.build.json && tsup src/recipes.ts --format esm --dts --dts-only --clean false --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maidang1/mdx-handwritten.git",
    "directory": "packages/scene"
  },
  "homepage": "https://github.com/Maidang1/mdx-handwritten#readme",
  "bugs": {
    "url": "https://github.com/Maidang1/mdx-handwritten/issues"
  },
  "keywords": [
    "mdx",
    "annotation",
    "scene-plan",
    "handwritten"
  ]
}
