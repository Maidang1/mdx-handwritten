{
  "name": "@madinah/mdx-handwritten-remark",
  "version": "0.2.0",
  "description": "Strict handwritten UI directives for MDX",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "keywords": [
    "mdx",
    "remark",
    "directive",
    "handwritten"
  ],
  "dependencies": {
    "@madinah/mdx-handwritten-scene": "*",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-mdx-jsx": "^3.2.0",
    "unified": "^11.0.5",
    "vfile": "^6.0.3"
  },
  "peerDependencies": {
    "remark-directive": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maidang1/mdx-handwritten.git",
    "directory": "packages/remark"
  },
  "homepage": "https://github.com/Maidang1/mdx-handwritten#readme",
  "bugs": {
    "url": "https://github.com/Maidang1/mdx-handwritten/issues"
  },
  "engines": {
    "node": ">=20.19"
  }
}
