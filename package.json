{
  "name": "mdx-handwritten",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:packages && npm run build:docs",
    "build:packages": "npm run build -w mdx-handwritten-scene && npm run build -w remark-mdx-handwritten && npm run build -w mdx-handwritten-react",
    "build:docs": "npm run build -w @mdx-handwritten/docs",
    "dev": "npm run dev -w @mdx-handwritten/docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.19"
  },
  "devDependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
